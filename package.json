{
  "name": "tlef-financebot",
  "version": "0.0.1",
  "description": "TLEF boilerplate: TypeScript client/server skeleton with isolated, documented integrations (MongoDB, Qdrant, SAML auth, ubc-genai-toolkit).",
  "homepage": "https://github.com/ubc/tlef-financebot#readme",
  "bugs": {
    "url": "https://github.com/ubc/tlef-financebot/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ubc/tlef-financebot.git"
  },
  "license": "GPL-2.0-only",
  "author": "",
  "type": "commonjs",
  "main": "server/dist/server.js",
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:server": "tsx watch server/src/server.ts",
    "dev:client": "tsc -p client/tsconfig.json --watch",
    "build": "npm-run-all build:server build:client",
    "build:server": "tsc -p server/tsconfig.json",
    "build:client": "tsc -p client/tsconfig.json",
    "start": "node server/dist/server.js",
    "saml:fetch-cert": "node scripts/fetch-idp-cert.mjs",
    "typecheck": "npm-run-all typecheck:server typecheck:client",
    "typecheck:server": "tsc -p server/tsconfig.json --noEmit",
    "typecheck:client": "tsc -p client/tsconfig.json --noEmit",
    "test": "jest",
    "test:unit": "jest",
    "test:unit:watch": "jest --watch",
    "test:unit:coverage": "jest --coverage",
    "test:unit:monocart": "jest -c jest.monocart.config.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:a11y": "playwright test -c playwright.a11y.config.ts",
    "test:report": "playwright show-report"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.18.0",
    "@types/multer": "^2.2.0",
    "connect-mongo": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "mongodb": "^7.4.0",
    "multer": "^2.2.0",
    "node-fetch": "^3.3.2",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "passport-saml": "^3.2.4",
    "passport-ubcshib": "^0.1.6",
    "ubc-genai-toolkit-chunking": "^0.1.0",
    "ubc-genai-toolkit-core": "^0.1.0",
    "ubc-genai-toolkit-document-parsing": "^0.2.0",
    "ubc-genai-toolkit-embeddings": "^0.1.1",
    "ubc-genai-toolkit-llm": "^0.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "jest-monocart-coverage": "^1.1.1",
    "npm-run-all": "^4.1.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
