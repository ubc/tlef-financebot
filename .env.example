# =============================================================================
# Environment variables for the TLEF boilerplate.
#
# Copy this file to `.env` and adjust values for your environment. Every
# variable below is read (with a sensible default) in server/src/config/env.ts
# and consumed by the component it is grouped under — see that component's
# AGENTS.md for details. The defaults target the local docker backing services
# (MongoDB, docker-simple-saml, Qdrant) and a local Ollama.
# =============================================================================

# --- Core server -------------------------------------------------------------
NODE_ENV=development
PORT=6118

# --- MongoDB (server/src/components/mongodb) ---------------------------------
# Matches the local tlef-mongodb-docker container, which runs with auth enabled.
# The credentials are that container's defaults (MONGO_INITDB_ROOT_USERNAME /
# MONGO_INITDB_ROOT_PASSWORD); because the root user lives in the `admin`
# database, the connection string must include authSource=admin.
# See https://github.com/ubc/tlef-mongodb-docker
MONGODB_URI=mongodb://mongoadmin:secret@localhost:27017/?authSource=admin
MONGODB_DB_NAME=financebot

# --- Session store (server/src/components/auth) ------------------------------
# Secret used to sign the session cookie. Use a long random string.
SESSION_SECRET=change-me-in-production

# --- Qdrant vector DB (server/src/components/qdrant) -------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=super-secret-dev-key
QDRANT_COLLECTION=financebot

# --- UBC Academic API (server/src/components/academic-api) -------------------
# Course sections, registrations, and person lookups. Locally this targets the
# FakeAcademicAPI container (../services/FakeAcademicAPI, port 3689), which
# mirrors the real API's shapes. On staging/production set the same variables to
# the real Academic API and your real client credentials.
ACADEMIC_API_URL=http://localhost:3689
ACADEMIC_API_CLIENT_ID=mock-client
ACADEMIC_API_CLIENT_SECRET=mock-secret

# --- SAML / Shibboleth auth (server/src/components/auth) ---------------------
# Uses passport-ubcshib against the local docker-simple-saml IdP.
# See https://github.com/ubc/docker-simple-saml and the "Authentication"
# section of the README for the full setup (SP entry + IdP certificate).
#
# LOCAL | STAGING | PRODUCTION. LOCAL targets docker-simple-saml.
SAML_ENVIRONMENT=LOCAL
#
# Your app's Service Provider entity ID and ACS callback. These MUST exactly
# match an SP entry in docker-simple-saml's saml20-sp-remote.php. The defaults
# below match the port-6118 SP entry that IdP ships with. If you run on a
# different PORT, change these and add a matching SP entry (see README).
SAML_ISSUER=http://localhost:6118
SAML_CALLBACK_URL=http://localhost:6118/auth/ubcshib/callback
#
# The local IdP runs on :6122 (docker-simple-saml maps 6122 -> container :80).
SAML_ENTRY_POINT=http://localhost:6122/simplesaml/saml2/idp/SSOService.php
SAML_LOGOUT_URL=http://localhost:6122/simplesaml/saml2/idp/SingleLogoutService.php
SAML_IDP_METADATA_URL=http://localhost:6122/simplesaml/saml2/idp/metadata.php
#
# Path to the IdP's public signing certificate (PEM). passport-ubcshib requires
# it. Populate it with `npm run saml:fetch-cert` (IdP must be running) or by
# copying docker-simple-saml/cert/server.crt to this path. Git-ignored.
SAML_IDP_CERT_PATH=./server/certs/idp.pem
#
# Force re-authentication at the IdP on every login. With 'true', logging out
# and back in returns you to the IdP login page instead of silently reusing the
# IdP's SSO session (useful in dev for switching test users). Set 'false' in
# production if you want cross-app single sign-on.
SAML_FORCE_AUTHN=true
#
# Where to send the browser after login / logout.
POST_LOGIN_REDIRECT=/
POST_LOGOUT_REDIRECT=/

# --- GenAI toolkit: LLM (server/src/components/genai/llm) --------------------
# Chat / text generation via ubc-genai-toolkit-llm.
# LLM_PROVIDER is one of: ollama | openai | anthropic | ubc-llm-sandbox
#   - ollama:          set LLM_ENDPOINT (default http://localhost:11434), no key
#   - openai:          set LLM_API_KEY (LLM_ENDPOINT optional for OpenAI-compatible gateways)
#   - anthropic:       set LLM_API_KEY
#   - ubc-llm-sandbox: set LLM_API_KEY and LLM_ENDPOINT
# The defaults below target a local Ollama with a small, fast model. NOTE:
# "thinking" models (e.g. qwen3, gemma3/4, gpt-oss) spend the token budget on a
# hidden reasoning channel and can return EMPTY content unless given a very
# large maxTokens; prefer a non-thinking model (like ministral-3) for this demo.
LLM_PROVIDER=ollama
LLM_DEFAULT_MODEL=ministral-3:latest
LLM_ENDPOINT=http://localhost:11434
LLM_API_KEY=

# --- GenAI toolkit: embeddings (server/src/components/genai/embeddings) ------
# Text -> vectors via ubc-genai-toolkit-embeddings. EMBEDDINGS_PROVIDER is
# either `fastembed` (fully local, self-contained; bge-small-en-v1.5 -> 384-dim)
# or an LLM provider name (ollama | openai | ...) that also serves embeddings.
# When it is an LLM provider, LLM_ENDPOINT / LLM_API_KEY above are reused.
# The model fixes the vector dimension, which MUST match the Qdrant collection
# size; the RAG example derives the size from the model at runtime so they
# cannot drift. The defaults match CREATE's local 384-dimensional FastEmbed
# model. `nomic-embed-text` on Ollama is 768-dim.
EMBEDDINGS_PROVIDER=fastembed
EMBEDDINGS_MODEL=fast-bge-small-en-v1.5

# --- GenAI toolkit: logging (server/src/components/genai) --------------------
# The toolkit modules log verbose debug/info by default; we suppress that to
# keep the app's own logs readable, surfacing only their warnings/errors. Set to
# true to restore the toolkit's full debug output when diagnosing it.
GENAI_DEBUG=false

# --- Per-pipeline-step LLM model overrides (server/src/config/env) -----------
# Each falls back to LLM_DEFAULT_MODEL when unset (AD-07, per-step selection).
LLM_MODEL_GENERATOR=
LLM_MODEL_VALIDATOR=
LLM_MODEL_REVIEWER=
LLM_MODEL_MASTERY_EVALUATOR=

# Comma-separated CWL PUIDs with platform Admin access.
ADMIN_CWL_ALLOWLIST=PUID-ADMIN-0001

# Parameterized-question worker sandbox limits.
PARAM_WORKER_TIMEOUT_MS=2000
PARAM_WORKER_MEMORY_MB=64
