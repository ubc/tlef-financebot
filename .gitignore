# Dependencies
node_modules/

# Environment
.env
.env.local

# Build output
server/dist/
client/public/js/
client/public/vendor/

# Test output + reports
coverage-reports/
playwright-report/
playwright-report-a11y/
test-results/
blob-report/
.last-run.json
# Saved e2e login session (regenerated by global-setup each run)
