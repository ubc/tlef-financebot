server/certs/

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
*.tsbuildinfo

# fastembed local model cache (downloaded on first use by
# components/genai/embeddings; see scripts/ingest-spike.ts)
local_cache/

# Uploaded course materials (server/src/services/materials.service.ts) — disk
# storage for multer, not a build artifact but never committed.
uploads/
